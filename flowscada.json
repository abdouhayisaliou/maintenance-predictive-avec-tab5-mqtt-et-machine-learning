    {
        "id": "fn_generate_cnc",
        "type": "function",
        "z": "tab_scada_cnc",
        "d": true,
        "name": "Générer données CNC",
        "func": "const r = Math.random();\n\nlet state = \"NORMAL\";\n\nif (r < 0.70) {\n    state = \"NORMAL\";\n} else if (r < 0.85) {\n    state = \"FATIGUE\";\n} else if (r < 0.95) {\n    state = \"DEGRADE\";\n} else {\n    state = \"CRITIQUE\";\n}\n\nlet data = {\n    machine: \"CNC_MAZAK_SIM\",\n    timestamp: new Date().toISOString(),\n    machine_state: state\n};\n\nif (state === \"NORMAL\") {\n    data.spindle_temp = 55 + Math.random() * 15;\n    data.motor_temp = 50 + Math.random() * 12;\n    data.hydraulic_pressure = 90 + Math.random() * 25;\n    data.vibration = 0.15 + Math.random() * 0.35;\n    data.motor_current = 4 + Math.random() * 2;\n    data.spindle_speed = 1200 + Math.random() * 900;\n    data.tool_load = 35 + Math.random() * 25;\n    data.air_pressure = 6 + Math.random() * 1.2;\n    data.coolant_flow = 8 + Math.random() * 3;\n}\n\nelse if (state === \"FATIGUE\") {\n    data.spindle_temp = 70 + Math.random() * 10;\n    data.motor_temp = 62 + Math.random() * 10;\n    data.hydraulic_pressure = 115 + Math.random() * 20;\n    data.vibration = 0.55 + Math.random() * 0.35;\n    data.motor_current = 6 + Math.random() * 1.5;\n    data.spindle_speed = 1200 + Math.random() * 900;\n    data.tool_load = 55 + Math.random() * 20;\n    data.air_pressure = 5.8 + Math.random() * 1;\n    data.coolant_flow = 6 + Math.random() * 2;\n}\n\nelse if (state === \"DEGRADE\") {\n    data.spindle_temp = 80 + Math.random() * 12;\n    data.motor_temp = 72 + Math.random() * 12;\n    data.hydraulic_pressure = 135 + Math.random() * 25;\n    data.vibration = 0.9 + Math.random() * 0.45;\n    data.motor_current = 7.5 + Math.random() * 2;\n    data.spindle_speed = 1200 + Math.random() * 900;\n    data.tool_load = 70 + Math.random() * 18;\n    data.air_pressure = 5.2 + Math.random() * 1;\n    data.coolant_flow = 4 + Math.random() * 2;\n}\n\nelse if (state === \"CRITIQUE\") {\n    data.spindle_temp = 92 + Math.random() * 15;\n    data.motor_temp = 88 + Math.random() * 12;\n    data.hydraulic_pressure = 160 + Math.random() * 25;\n    data.vibration = 1.3 + Math.random() * 0.6;\n    data.motor_current = 9 + Math.random() * 3;\n    data.spindle_speed = 1200 + Math.random() * 900;\n    data.tool_load = 85 + Math.random() * 15;\n    data.air_pressure = 4.8 + Math.random() * 0.8;\n    data.coolant_flow = 2 + Math.random() * 2;\n}\n\nmsg.payload = data;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 120,
        "wires": [
            []
        ]
    },
