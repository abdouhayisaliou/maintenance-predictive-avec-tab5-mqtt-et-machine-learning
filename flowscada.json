    {
        "id": "5a3b321cd6d41e1c",
        "type": "function",
        "z": "tab_scada_cnc",
        "d": true,
        "name": "IA Simulée",
        "func": "const temp = msg.payload.spindle_temp;\nconst vib = msg.payload.vibration;\nconst pressure = msg.payload.hydraulic_pressure;\n\nlet prediction = \"NORMAL\";\n\nif (temp > 90 || vib > 1.3) {\n    prediction = \"CRITIQUE\";\n}\nelse if (temp > 80 || vib > 0.9) {\n    prediction = \"DEGRADE\";\n}\nelse if (temp > 70 || vib > 0.6) {\n    prediction = \"FATIGUE\";\n}\n\nmsg.payload = {\n    prediction: prediction,\n    confidence: Math.floor(Math.random() * 10) + 90\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
