    {
        "id": "386c847ee4555c89",
        "type": "function",
        "z": "tab_scada_cnc",
        "name": "Alert",
        "func": "let data = msg.payload;\n\nif (typeof data === \"string\") {\n    data = JSON.parse(data);\n}\n\nconst prediction = data.prediction;\nconst score = data.health_score;\n\nif (prediction === \"NORMAL\") {\n    msg.payload = \"🟢 Aucun risque — machine stable\";\n}\nelse if (prediction === \"FATIGUE\") {\n    msg.payload = \"🟡 Surveillance renforcée — signes de fatigue\";\n}\nelse if (prediction === \"DEGRADE\") {\n    msg.payload = \"🟠 Maintenance recommandée — dérive détectée\";\n}\nelse if (prediction === \"CRITIQUE\") {\n    msg.payload = \"🔴 Arrêt imminent — intervention urgente\";\n}\nelse {\n    msg.payload = \"⚪ État inconnu\";\n}\n\nmsg.payload += \" | Santé : \" + score + \"%\";\n\nreturn msg;",
